{
  "$schema": "https://opencode.ai/config.json",

  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "{file:.secrets/aws-region}",
        "profile": "{file:.secrets/aws-profile}",
      },
    },
    "anthropic": {
      "options": {
        "baseURL": "{file:.secrets/anthropic-base-url}",
        "apiKey": "{file:.secrets/anthropic-api-key}",
      },
    },
  },

  "instructions": ["./AGENTS.md"],

  "formatter": {
    "ruff": {
      "command": ["ruff", "format", "$FILE"],
      "extensions": [".py", ".pyi"],
    },

    "stylua": {
      "command": [
        "stylua",
        "--indent-type",
        "Spaces",
        "--indent-width",
        "2",
        "--column-width",
        "120",
        "$FILE",
      ],
      "extensions": [".lua"],
    },

    "prettier-web": {
      "command": ["npx", "--yes", "prettier", "--write", "$FILE"],
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".css", ".html"],
    },

    "prettier-config": {
      "command": ["npx", "--yes", "prettier", "--write", "$FILE"],
      "extensions": [".json", ".jsonc", ".yaml", ".yml"],
    },

    "shfmt": {
      "command": ["shfmt", "-w", "$FILE"],
      "extensions": [".sh", ".bash"],
    },
  },

  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      ".venv/**",
      ".idea/**",
      ".ruff_cache/**",
      "__pycache__/**",
      "**/*.pyc",
      "coverage/**",
      ".pytest_cache/**",
      ".aws-sam/**",
      "**/*.egg-info/**",
      "dist/**",
      "build/**",
      "frontend/node_modules/**",
      "frontend/dist/**",
    ],
  },

  "autoupdate": "notify",

  "plugin": ["opencode-with-claude", "@tarquinen/opencode-dcp"],
}
